# === 依赖目录 (核心) ===
node_modules/
.pnp
.pnp.js

# === 构建产物 (打包生成) ===
dist/
dist-ssr/
*.local

# === 环境变量与敏感信息 (新增重要项) ===
# 保留 .env.example 作为模板，忽略包含本地密钥的文件
.env
.env.local
.env.*.local

# === 日志文件 ===
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === 操作系统临时文件 (新增) ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# === 编辑器与 IDE 配置 ===
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea
*.suo
*.ntvs*
*.njsproj
*.sln

# === 测试覆盖率与缓存 ===
coverage/
*.lcov
.eslintcache
.stylelintcache

# === TypeScript 构建缓存 ===
*.tsbuildinfo

# === Vite 专属缓存 (新增) ===
# Vite 在 dev 模式下生成的预构建依赖缓存
.vite/

# === 测试工具截图/视频 (保留原样) ===
# Cypress
/cypress/videos/
/cypress/screenshots/
# Vitest
__screenshots__/

# === 其他杂项 ===
# 某些自动生成的类型定义文件
src/**/*.d.ts